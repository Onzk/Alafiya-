generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Permission {
  id              String           @id @default(cuid())
  code            String           @unique
  description     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  roles           RolePermission[]
  userPermissions UserPermission[]
}

model Role {
  id           String           @id @default(cuid())
  nom          String
  description  String?
  creePar      CreateurRole
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  centreId     String?
  centre       Centre?          @relation(fields: [centreId], references: [id])
  permissions  RolePermission[]
  utilisateurs User[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Specialite {
  id              String                  @id @default(cuid())
  nom             String
  code            String                  @unique
  description     String?
  estActive       Boolean                 @default(true)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  enregistrements EnregistrementMedical[]
  userSpecialites UserSpecialite[]
}

model Centre {
  id                String                  @id @default(cuid())
  nom               String
  adresse           String
  telephone         String
  email             String
  region            String
  prefecture        String
  type              TypeCentre
  estActif          Boolean                 @default(true)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  adminId           String?                 @unique
  creeParId         String?
  accesEnCours      AccesDossier[]
  accesUrgences     AccesUrgence[]
  admin             User?                   @relation("CentreAdmin", fields: [adminId], references: [id])
  creePar           User?                   @relation("CentreCreePar", fields: [creeParId], references: [id])
  enregistrements   EnregistrementMedical[]
  logs              Log[]
  patients          Patient[]
  roles             Role[]
  utilisateursActif User[]                  @relation("CentreActif")
  utilisateurs      UserCentre[]
}

model User {
  id              String                  @id @default(cuid())
  nom             String
  prenoms         String
  email           String                  @unique
  motDePasse      String
  telephone       String?
  niveauAcces     NiveauAcces
  photo           String?
  estActif        Boolean                 @default(true)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  roleId          String?
  centreActifId   String?
  creeParId       String?
  typePersonnelId String?
  accesEnCours    AccesDossier[]
  accesUrgences   AccesUrgence[]
  centreAdminDe   Centre?                 @relation("CentreAdmin")
  centresCrees    Centre[]                @relation("CentreCreePar")
  enregistrements EnregistrementMedical[]
  logs            Log[]
  otps            OTP[]
  patientsCrees   Patient[]
  centreActif     Centre?                 @relation("CentreActif", fields: [centreActifId], references: [id])
  creePar         User?                   @relation("UserCreePar", fields: [creeParId], references: [id])
  typePersonnel   TypePersonnel?          @relation(fields: [typePersonnelId], references: [id])
  creeParOf       User[]                  @relation("UserCreePar")
  role            Role?                   @relation(fields: [roleId], references: [id])
  centres         UserCentre[]
  permissions     UserPermission[]
  specialites     UserSpecialite[]
}

model UserCentre {
  userId   String
  centreId String
  centre   Centre @relation(fields: [centreId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, centreId])
}

model UserSpecialite {
  userId       String
  specialiteId String
  specialite   Specialite @relation(fields: [specialiteId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, specialiteId])
}

model TypePersonnel {
  id           String   @id @default(cuid())
  nom          String
  code         String   @unique
  description  String?
  estActif     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  utilisateurs User[]
}

model UserPermission {
  userId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
}

model Patient {
  id                    String          @id @default(cuid())
  nom                   String
  prenoms               String
  genre                 Genre
  dateNaissance         DateTime
  dateNaissancePresumee Boolean         @default(false)
  adresse               String
  telephone             String?
  email                 String?
  numeroCNI             String?
  qrToken               String          @unique
  qrGeneratedAt         DateTime        @default(now())
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  urgenceNom            String
  urgencePrenoms        String
  urgenceTel            String
  urgenceAdresse        String
  urgenceRelation       String
  creeParId             String
  centreCreationId      String
  accesUrgences         AccesUrgence[]
  dossier               DossierMedical?
  otps                  OTP[]
  centreCreation        Centre          @relation(fields: [centreCreationId], references: [id])
  creePar               User            @relation(fields: [creeParId], references: [id])
}

model DossierMedical {
  id              String                  @id @default(cuid())
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  patientId       String                  @unique
  accesEnCours    AccesDossier[]
  patient         Patient                 @relation(fields: [patientId], references: [id], onDelete: Cascade)
  enregistrements EnregistrementMedical[]
}

model AccesDossier {
  id           String         @id @default(cuid())
  debutAcces   DateTime       @default(now())
  finAcces     DateTime
  modeUrgence  Boolean        @default(false)
  dossierId    String
  medecinId    String
  centreId     String
  specialiteId String?
  centre       Centre         @relation(fields: [centreId], references: [id])
  dossier      DossierMedical @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  medecin      User           @relation(fields: [medecinId], references: [id])
}

model EnregistrementMedical {
  id                      String         @id @default(cuid())
  antecedents             String?
  signes                  String?
  examens                 String?
  bilan                   String?
  traitConseils           String?
  traitInjections         String?
  traitOrdonnance         String?
  suivi                   String?
  audioTranscriptionBrute String?
  genereParIA             Boolean        @default(false)
  valideParMedecin        Boolean        @default(true)
  dateConsultation        DateTime       @default(now())
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  dossierId               String
  specialiteId            String
  medecinId               String
  centreId                String
  centre                  Centre         @relation(fields: [centreId], references: [id])
  dossier                 DossierMedical @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  medecin                 User           @relation(fields: [medecinId], references: [id])
  specialite              Specialite     @relation(fields: [specialiteId], references: [id])
}

model OTP {
  id        String   @id @default(cuid())
  code      String
  telephone String
  expireAt  DateTime
  utilise   Boolean  @default(false)
  createdAt DateTime @default(now())
  patientId String
  medecinId String
  medecin   User     @relation(fields: [medecinId], references: [id])
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model AccesUrgence {
  id                   String                    @id @default(cuid())
  justification        String
  dateAcces            DateTime                  @default(now())
  createdAt            DateTime                  @default(now())
  justifieParType      TypeJustificateurUrgence?
  justifieParNom       String?
  justifieParTel       String?
  justifieParSignature String?
  patientId            String
  medecinId            String
  centreId             String
  centre               Centre                    @relation(fields: [centreId], references: [id])
  medecin              User                      @relation(fields: [medecinId], references: [id])
  patient              Patient                   @relation(fields: [patientId], references: [id])
}

model Log {
  id        String    @id @default(cuid())
  action    ActionLog
  cible     String?
  cibleId   String?
  details   Json?
  ip        String?
  userAgent String?
  createdAt DateTime  @default(now())
  userId    String?
  centreId  String?
  centre    Centre?   @relation(fields: [centreId], references: [id])
  user      User?     @relation(fields: [userId], references: [id])
}

enum NiveauAcces {
  MINISTERE
  ADMIN_CENTRE
  PERSONNEL
}

enum TypeCentre {
  HOPITAL
  CLINIQUE
  CSU
  CMS
  AUTRE
}

enum Genre {
  M
  F
}

enum ActionLog {
  LOGIN
  LOGOUT
  SCAN_QR
  ENVOI_OTP
  VALIDATION_OTP
  ACCES_DOSSIER
  MODIFICATION_DOSSIER
  URGENCE_ACTIVATION
  CREATION_PATIENT
  CREATION_USER
  CREATION_CENTRE
  CREATION_ROLE
  MODIFICATION_PERMISSIONS
}

enum CreateurRole {
  MINISTERE
  CENTRE
}

enum TypeJustificateurUrgence {
  PATIENT
  PERSONNE_URGENCE
}
